# Dependencies
node_modules/

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python cache/build output
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Local databases and SQLite runtime files
*.sqlite
*.sqlite3
*.db
*.db-*

# Runtime data generated by Flask
backend/documents/
backend/uploads/
backend/data/users.local.json

# Keep seeded demo data out of future adds if it is untracked in a fresh clone.
# It is currently tracked in this repo and should be untracked separately if you
# want to remove plaintext demo credentials from version control history.
backend/data/users.json

# Logs and temporary files
logs/
*.log
*.tmp
*.temp
tmp/
temp/

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini

# IDE/editor local settings
.vscode/
.idea/
*.swp
*.swo

# Local prompt/instruction scratch files
prompt*.txt

# Office/export artifacts
*.docx
*.pdf

# Ignore signature
backend/assets/signatures/
